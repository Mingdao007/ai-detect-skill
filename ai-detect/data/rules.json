{
  "version": 1,
  "rules": [
    {
      "rule_id": "placeholder_title__final_split",
      "category": "placeholder_title",
      "status": "confirmed",
      "patterns": [
        {
          "type": "regex",
          "value": "^\\s*Final split\\s*$"
        }
      ],
      "examples": [
        "Final split"
      ],
      "rewrite_direction": "Replace workflow-like slide titles with the actual content title.",
      "evidence_count": 1
    },
    {
      "rule_id": "template_label__question_number",
      "category": "template_label",
      "status": "confirmed",
      "patterns": [
        {
          "type": "regex",
          "value": "^\\s*Question\\s+\\d+(?:\\s*\\([^\\n]+\\))?:?\\s*$"
        }
      ],
      "examples": [
        "Question 1",
        "Question 1 (Convergence speed):"
      ],
      "rewrite_direction": "Replace question-number labels with the real subsection title.",
      "evidence_count": 1
    },
    {
      "rule_id": "template_label__answer_label",
      "category": "template_label",
      "status": "confirmed",
      "patterns": [
        {
          "type": "regex",
          "value": "^\\s*Answer:\\s*$"
        }
      ],
      "examples": [
        "Answer:"
      ],
      "rewrite_direction": "Remove the answer label and start with the actual content.",
      "evidence_count": 1
    },
    {
      "rule_id": "template_label__task_number",
      "category": "template_label",
      "status": "confirmed",
      "patterns": [
        {
          "type": "regex",
          "value": "^\\s*Task\\s+\\d+(?:\\s*\\([^\\n]+\\))?(?:\\s*[:.-]\\s*[A-Z][^\\n]*|\\s+[A-Z][^\\n]*)?\\s*$"
        }
      ],
      "examples": [
        "Task 3"
      ],
      "rewrite_direction": "Replace task-number labels with a content-native subsection title.",
      "evidence_count": 1
    },
    {
